# Copy to Render environment variables (do not commit real secrets)

# Neon PostgreSQL — use JDBC format:
# jdbc:postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/testdb
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

ADMIN_EMAIL=admin@school.example
ADMIN_PASSWORD=

# Comma-separated Angular origins (local + Vercel production URL)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,https://your-app.vercel.app

# Render sets PORT automatically — no need to configure locally unless overriding
