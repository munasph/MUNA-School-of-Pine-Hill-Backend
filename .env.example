# Copy to .env for local dev, or set these on Render (never commit real secrets)
#
# Render Web Service (manual setup):
#   Language: Docker
#   Dockerfile: ./Dockerfile (auto-detected)
#   Health: /api/health
#   Or use render.yaml → New → Blueprint
#
# Neon PostgreSQL — JDBC format (user/password as separate vars, not in URL):
# DATABASE_URL=jdbc:postgresql://YOUR-HOST.neon.tech/neondb?sslmode=require
# DATABASE_USERNAME=neondb_owner
# DATABASE_PASSWORD=your_password_here
DATABASE_URL=jdbc:postgresql://YOUR-HOST.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=

ADMIN_EMAIL=admin@school.example
ADMIN_PASSWORD=

# JWT secret — use a long random string in production (min 32 characters)
APP_JWT_SECRET=dev-only-change-me-use-32-char-secret-key!!

# Comma-separated frontend origins (no trailing slashes)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,https://muna-school-of-pine-hill-cmtaaud0s.vercel.app,https://muna-school-of-pine-hill-muna-school-of-pine-hill-s-projects.vercel.app,https://munasph.org,https://www.munasph.org

# Public URL of the Angular app — used to build email verification/reset links
APP_FRONTEND_BASE_URL=https://munasph.org

# Email (SMTP). Leave APP_MAIL_ENABLED=false to log links to the console (dev/no provider).
# To send real email, set APP_MAIL_ENABLED=true and fill in your SMTP provider details.
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@munasph.org
APP_MAIL_HOST=
APP_MAIL_PORT=587
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=

# Account security (optional overrides)
# APP_MAX_FAILED_LOGINS=5
# APP_LOCKOUT_MINUTES=15
# APP_EMAIL_TOKEN_TTL_MINUTES=1440
# APP_RESET_TOKEN_TTL_MINUTES=60
# APP_MAGIC_LINK_TTL_MINUTES=15

# Portal login methods — toggle each independently (frontend reads GET /api/portal/auth/methods)
APP_AUTH_PASSWORD_ENABLED=true
APP_AUTH_MAGIC_LINK_ENABLED=true
# Google sign-in: scaffolded but off until you add an OAuth client id
APP_AUTH_GOOGLE_ENABLED=false
APP_AUTH_GOOGLE_CLIENT_ID=

# Render sets PORT automatically — no need to configure locally unless overriding
